---
import { fetchProductsByCollections } from "../lib/api/products";
import { formatPrice } from "../utils";

type Props = Partial<{
    title: string;
    titleLines: string[];
    ctaHref: string;
    ctaLabel: string;
    collection: string;
    limit: number;
    gridClass: string;
    sectionClass: string;
}>;

const {
    title = "",
    titleLines = [],
    ctaHref,
    ctaLabel = "See All",
    collection = "",
    limit = 4,
    gridClass = "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6",
    sectionClass = "bg-white py-16",
} = Astro.props;

const response = await fetchProductsByCollections({
    collections: [collection],
    limit,
});
const items = response.items;
---

<section class={sectionClass}>
    <div class="max-w-[1280px] mx-auto px-6 lg:px-12">
        <div
            class:list={[
                {
                    "mb-8": !ctaHref,
                    "flex justify-between items-start mb-12": ctaHref,
                },
            ]}
        >
            <h2
                class="text-[48px] leading-[1.1] font-black tracking-[-1.6px] uppercase"
            >
                {
                    titleLines.length
                        ? titleLines.map((line, index) => (
                              <>
                                  {line}
                                  {index < titleLines.length - 1 ? (
                                      <br />
                                  ) : null}
                              </>
                          ))
                        : title
                }
            </h2>
            {
                ctaHref ? (
                    <a
                        href={ctaHref}
                        class="text-sm opacity-60 hover:opacity-100 transition"
                    >
                        {ctaLabel}
                    </a>
                ) : null
            }
        </div>

        <div class={gridClass}>
            {
                items.map((product) => (
                    <a href={`/product/${product.id}`} class="group block">
                        <div class="relative aspect-[3/4] bg-gray-100 border border-line overflow-hidden mb-4">
                            <img
                                src={product.image}
                                alt={product.name}
                                class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
                            />
                            <button
                                type="button"
                                class="absolute bottom-4 right-4 w-[34px] h-[34px] bg-overlay/70 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition"
                            >
                                <img
                                    src="/icons/heart.svg"
                                    alt="Wishlist"
                                    class="w-4 h-4"
                                />
                            </button>
                        </div>
                        <p class="text-xs opacity-60 mb-1 font-medium capitalize">
                            {product.category}
                        </p>
                        <h3 class="text-sm capitalize mb-1 font-medium">
                            {product.name}
                        </h3>
                        <p class="text-sm font-medium">
                            ${formatPrice(Number(product.price))}
                        </p>
                    </a>
                ))
            }
        </div>
    </div>
</section>
