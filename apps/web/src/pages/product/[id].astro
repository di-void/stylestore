---
import StoreLayout from "../../layouts/store-layout.astro";
import { formatPrice } from "../../utils";
import { AddToCartControls } from "../../components/add-to-cart";
import {
    fetchProductById,
    fetchRelatedProducts,
} from "../../lib/api/products";

const { id = "" } = Astro.params;
let product = null;

try {
    product = await fetchProductById(id);
} catch {
    product = null;
}

const relatedProducts = product
    ? await fetchRelatedProducts({
          category: product.category,
          excludeId: product.id,
          limit: 4,
      })
    : [];
---

<StoreLayout title="StyleStore - Product">
    {
        !product ? (
            <div class="max-w-[1280px] mx-auto px-6 lg:px-12 py-16 text-center bg-white">
                <h1 class="text-2xl font-bold mb-4">Product not found</h1>
                <a
                    href="/"
                    class="text-sm opacity-60 hover:opacity-100 transition uppercase tracking-wide"
                >
                    Return to home
                </a>
            </div>
        ) : (
            <div class="bg-white">
                <div class="max-w-[1280px] mx-auto px-6 lg:px-12 py-8">
                    <nav class="text-xs mb-12 opacity-60 uppercase tracking-wide">
                        <a href="/" class="hover:opacity-100">
                            Home
                        </a>
                        <span class="mx-2">/</span>
                        <span class="capitalize">{product.category}</span>
                        <span class="mx-2">/</span>
                        <span class="opacity-100 text-black capitalize">
                            {product.name}
                        </span>
                    </nav>

                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
                        <div>
                            <div class="aspect-[3/4] bg-gray-100 border border-line overflow-hidden mb-6">
                                <img
                                    src={product.image}
                                    alt={product.name}
                                    class="w-full h-full object-cover"
                                />
                            </div>

                            <div class="grid grid-cols-4 gap-3">
                                {[1, 2, 3, 4].map((item) => (
                                    <div class="aspect-square bg-gray-100 border border-line overflow-hidden opacity-60">
                                        <img
                                            src={product.image}
                                            alt={`${product.name} ${item}`}
                                            class="w-full h-full object-cover"
                                        />
                                    </div>
                                ))}
                            </div>
                        </div>

                        <div class="pt-4">
                            <p class="text-[10px] tracking-[0.4px] uppercase opacity-40 mb-4 font-medium">
                                {product.category}
                            </p>
                            <h1 class="text-4xl font-black tracking-tight capitalize mb-4">
                                {product.name}
                            </h1>
                            <p class="text-2xl font-medium mb-8">
                                ${formatPrice(Number(product.price))}
                            </p>
                            <p class="text-sm opacity-60 leading-relaxed mb-12">
                                {product.description}
                            </p>

                            <AddToCartControls client:load product={product} />

                            <div class="border-t border-gray-200 pt-8 mt-8">
                                <h3 class="text-xs uppercase tracking-wide font-medium mb-4 opacity-60">
                                    Product Details
                                </h3>
                                <ul class="space-y-2 text-sm opacity-60">
                                    <li>Free shipping on orders over $100</li>
                                    <li>30-day return policy</li>
                                    <li>Premium quality materials</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="mt-24 border-t border-gray-200 pt-16">
                        <h2 class="text-2xl font-black uppercase tracking-tight mb-12">
                            You May Also Like
                        </h2>
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                            {relatedProducts.map((relatedProduct) => (
                                <a
                                    href={`/product/${relatedProduct.id}`}
                                    class="group block"
                                >
                                    <div class="relative aspect-[3/4] bg-gray-100 border border-line overflow-hidden mb-4">
                                        <img
                                            src={relatedProduct.image}
                                            alt={relatedProduct.name}
                                            class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
                                        />
                                    </div>
                                    <p class="capitalize text-xs opacity-60 mb-1 font-medium">
                                        {relatedProduct.category}
                                    </p>
                                    <h3 class="text-sm capitalize mb-1 font-medium">
                                        {relatedProduct.name}
                                    </h3>
                                    <p class="text-sm font-medium">
                                        $
                                        {formatPrice(
                                            Number(relatedProduct.price),
                                        )}
                                    </p>
                                </a>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        )
    }
</StoreLayout>
