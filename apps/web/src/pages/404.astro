---
import StoreLayout from "../layouts/store-layout.astro";
---

<StoreLayout title="StyleStore - Not Found">
    <div class="bg-white min-h-[60vh] flex items-center justify-center px-4">
        <div class="text-center">
            <h1 class="text-[80px] font-black tracking-tight mb-4">404</h1>
            <h2 class="text-2xl font-black uppercase tracking-tight mb-4">
                Page Not Found
            </h2>
            <p class="text-sm opacity-60 mb-12">
                The page you're looking for doesn't exist
            </p>
            <a
                href="/"
                class="inline-block h-[50px] px-12 bg-black text-white font-medium text-sm uppercase tracking-wide hover:bg-gray-800 transition leading-[50px]"
            >
                Go Home
            </a>
        </div>
    </div>
</StoreLayout>
